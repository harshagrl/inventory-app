# 🔗 Neon PostgreSQL connection string (Prisma CLI & App Runtime)
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@YOUR_NEON_HOST/neondb?sslmode=require"

# 🔐 NextAuth.js Secret (Generate using: openssl rand -base64 32)
NEXTAUTH_SECRET="YOUR_RANDOM_SECRET_HERE"

# 🌐 NextAuth.js URL (your app's base URL)
NEXTAUTH_URL="http://localhost:3000"
